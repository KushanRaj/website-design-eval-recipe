{
  "schemaVersion": 1,
  "site": {
    "name": "brightpath-education-test-site",
    "root": "."
  },
  "outputDir": "./screenshots/reference",
  "cleanOutputDir": true,
  "defaults": {
    "viewport": {
      "width": 1440,
      "height": 900
    },
    "deviceScaleFactor": 1,
    "waitUntil": "networkidle",
    "afterLoadWaitMs": 100,
    "timeoutMs": 30000,
    "screenshot": {
      "fullPage": false,
      "animations": "disabled",
      "caret": "hide"
    }
  },
